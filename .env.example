# --- 서버 ---
PORT=3003
NODE_ENV=production

# NAS docker-compose 볼륨 (호스트 경로). 프로필 사진은 이 경로 아래 profile-photos/
# NAS 의 /volume1/docker/familyboard/.env 에 반드시 맞는 값 넣기 (deploy.ps1 -PushEnv)
# NAS_DATA_DIR=/volume2/가족보드

# --- DB (NAS MySQL) ---
DB_HOST=192.168.11.31
DB_PORT=3307
DB_USER=kimjh
DB_PASSWORD=changeme
DB_NAME=familyboard

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
# 첫 부팅 시 기본 가족/관리자 자동 생성 (한 번만)
ADMIN_FAMILY_ALIAS=family
ADMIN_FAMILY_NAME=우리 가족
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=관리자

# --- 위치 (날씨/대기질 기본값: 도쿄 신주쿠 인근) ---
DEFAULT_LAT=35.6895
DEFAULT_LON=139.6917
DEFAULT_CITY=도쿄
DEFAULT_TZ=Asia/Tokyo

# --- Google Pollen API (선택) ---
# Google Cloud Console 에서 Pollen API 활성화 후 API 키 발급
# https://console.cloud.google.com/apis/library/pollen.googleapis.com
# 설정 시 TREE/GRASS/WEED 꽃가루 지수 (UPI 0-5) 를 사용, 미설정 시 Open-Meteo 로 폴백
# GOOGLE_POLLEN_API_KEY=

# --- 프로필 사진 파일 (선택) ---
# 기본: 컨테이너 /app/data/profile-photos → 호스트는 NAS_DATA_DIR 아래 profile-photos
# ⚠️ PROFILE_PHOTOS_DIR 에 /volume2/가족보드 처럼 NAS 호스트 경로를 넣지 마세요.
#    컨테이너에는 그 경로가 없어 파일이 NAS가 아니라 컨테이너에만 저장됩니다.
# 필요 시에만(거의 불필요): PROFILE_PHOTOS_DIR=/app/data/profile-photos
